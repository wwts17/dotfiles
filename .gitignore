# --- General ---
.DS_Store
*.swp
*.bak.*

# --- claude/ runtime state (not config) ---
claude/.claude/backups/
claude/.claude/cache/
claude/.claude/projects/
claude/.claude/shell-snapshots/
claude/.claude/todos/
claude/.claude/statsig/
claude/.claude/history.jsonl
claude/.claude/.credentials.json
claude/.claude/settings.local.json

# --- zsh/ runtime caches ---
zsh/.zcompdump*
zsh/.zsh_plugins.zsh

# --- nvim/ plugin lockfile (machine-specific) ---
nvim/.config/nvim/lazy-lock.json

# --- yazi/ flavors are managed by `ya pack`; don't vendor them ---
yazi/.config/yazi/flavors/
