{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(xargs grep:*)",
      "Bash(xargs rg:*)",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(*rm *\\**)",
      "Bash(*rm -rf *\\**)",
      "Bash(*rm -r *\\**)",
      "Bash(*rm -f *\\**)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "effortLevel": "xhigh",
  "tui": "default",
  "skipAutoPermissionPrompt": true
}
